# ============================================================
# AbsensiKu — Konfigurasi Server
# Salin file ini menjadi .env lalu isi nilainya
# cp .env.example .env
# ============================================================

# Port server (default: 3000)
PORT=3000

# ── Database ──
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=ganti_dengan_password_db_anda
DB_NAME=school_absensi

# ── JWT Token ──
# WAJIB DIGANTI dengan string acak panjang (min 32 karakter)
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=ganti_wajib_string_sangat_panjang_dan_acak_minimal_32_karakter
JWT_EXPIRES_IN=8h

# ── Environment ──
NODE_ENV=production
